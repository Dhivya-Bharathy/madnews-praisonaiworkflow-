# Copy to .env and fill in. Use the same keys in Netlify → Site configuration → Environment variables.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

NEWS_API_KEY=

PORT=3000

# Optional: merge DDG + Praison-curated articles (local: http://127.0.0.1:8790)
# On Netlify this MUST be a public HTTPS URL where you host praison-news (see README).
PRAISON_SERVICE_URL=
PRAISON_FETCH_TIMEOUT_MS=45000

OPENAI_MAX_TOKENS=800
FETCH_TIMEOUT_MS=9000
ARTICLE_MAX_AGE_DAYS=21
